# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_APP_NAME=VIZIIA Studio
VITE_APP_URL=https://demo.viziiastudio.com

# ─── API Server ────────────────────────────────────────────────────────────────
PORT=3000

# ─── Queue (BullMQ / Redis) ────────────────────────────────────────────────────
# Required by api/routes/generate.js and worker/worker.js
REDIS_URL=redis://localhost:6379

# ─── fal.ai ────────────────────────────────────────────────────────────────────
# Used for SAM2 lens segmentation and Qwen inpainting (Step 1 + Step 6)
FAL_API_KEY=

# ─── remove.bg ─────────────────────────────────────────────────────────────────
# Used to extract frame alpha in Step 1
REMOVEBG_API_KEY=

# ─── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Used for Gemini image generation (Steps 2 + 6)
# The pipeline calls `gcloud auth print-access-token` at runtime — no static token needed.
# Ensure gcloud ADC is configured: `gcloud auth application-default login`
GCP_PROJECT_ID=
# GCP_LOCATION and GCP_ACCESS_TOKEN are declared in REQUIRED_ENV but unused at runtime:
#   - Endpoint hardcodes "global" as location
#   - Token is fetched dynamically via gcloud CLI
# They are kept here for reference; remove from REQUIRED_ENV in pipeline/index.js when cleaning up.
GCP_LOCATION=global
GCP_ACCESS_TOKEN=

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
# Used for frame asset cache, temp composites, and final output delivery
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Provide credentials explicitly OR rely on IAM role / instance profile (leave blank for IAM).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Auth (JWT) ────────────────────────────────────────────────────────────────
# JWKS endpoint published by your identity provider (Auth0, Cognito, Clerk, etc.)
JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
# Token issuer claim — must match `iss` in the JWT exactly
JWT_ISSUER=https://your-idp.example.com/
# Token audience claim — must match `aud` in the JWT exactly
JWT_AUDIENCE=viziia-api

# ─── Optional tuning ───────────────────────────────────────────────────────────
# Seconds before signed S3 download URLs expire. Default: 3600 (1h).
# Use a shorter value when running on ECS/EC2 with STS-based IAM roles.
SIGNED_URL_TTL_SECONDS=3600

# MediaPipe sidecar URL. Default: http://localhost:8001
MEDIAPIPE_SERVICE_URL=http://localhost:8001
